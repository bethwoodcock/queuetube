{
  "manifest_version": 3,
  "name": "QueueTube",
  "version": "1.1.0",
  "description": "Queue your YouTube subscription feed and watch videos back-to-back like a playlist. Tag channels to queue by category.",
  "homepage_url": "https://github.com/bethwoodcock/queuetube/",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "QueueTube",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}