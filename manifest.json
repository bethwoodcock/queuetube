{
  "manifest_version": 3,
  "name": "QueueTube",
  "version": "1.0.0",
  "description": "Queue your YouTube subscription feed and watch videos back-to-back like a playlist. Scroll to load videos, click Queue, and enjoy hands-free viewing.",
  "homepage_url": "https://bethwoodcock.neocities.org/tools/queuetube",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "QueueTube"
  }
}
